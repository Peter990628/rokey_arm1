# Shared service addresses
PHARMACY_BACKEND_URL=http://127.0.0.1:8000
PHARMACY_DONE_URL=http://127.0.0.1:8000/api/tasks/refill/

# Replace these values before running on a shared network.
PHARMACY_UI_SECRET_KEY=replace-with-a-random-value
DJANGO_SECRET_KEY=replace-with-a-random-value
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Leave DB_ENGINE unset to use local SQLite. For PostgreSQL/Supabase, set:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=postgres
# DB_USER=replace-with-database-user
# DB_PASSWORD=replace-with-database-password
# DB_HOST=replace-with-database-host
# DB_PORT=5432
